{
  "name": "waht",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "docker compose up --watch",
    "build": "docker compose build",
    "down": "docker compose down",
    "lint": "eslint apps/ packages/shared/src",
    "format:check": "prettier --check .",
    "prepare": "node -e \"if(process.env.CI !== 'true') { require('child_process').execSync('husky') }\""
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^9.0.0",
    "eslint-plugin-vue": "^10.8.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.0.0",
    "typescript-eslint": "^8.58.0",
    "vue-eslint-parser": "^10.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx,vue}": [
      "prettier --write"
    ],
    "**/*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
