{
  "name": "@waht/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && tsc-alias",
    "start": "node --require tsconfig-paths/register dist/index.js",
    "lint": "echo 'lint handled at root'",
    "format:check": "prettier --check src",
    "typecheck": "tsc --noEmit",
    "prisma:migrate": "prisma migrate dev --schema ./prisma",
    "prisma:generate": "prisma generate --schema ./prisma",
    "prisma:studio": "prisma studio --schema ./prisma",
    "prisma:reset": "prisma migrate reset --schema ./prisma"
  },
  "devDependencies": {
    "@types/ioredis": "^4.28.10",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/oauth2": "^8.2.0",
    "@fastify/session": "^11.1.1",
    "@prisma/client": "^6.19.2",
    "@waht/shared": "file:../../packages/shared",
    "fastify": "^5.8.2",
    "ioredis": "^5.10.1",
    "pino-pretty": "^13.0.0",
    "prisma": "^6.19.2",
    "tsconfig-paths": "^4.2.0"
  }
}
